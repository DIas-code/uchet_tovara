# Скопируйте этот файл в .env.local и заполните значениями из Supabase
# (Project Settings → API). Файл .env.local в git не попадает.

# URL проекта Supabase, например https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Публичный anon-ключ (можно отдавать в браузер, защищён через RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Сервисный ключ — ТОЛЬКО на сервере, НИКОГДА не в браузер.
# Нужен для административных задач (создание бутиков владельцем).
SUPABASE_SERVICE_ROLE_KEY=
